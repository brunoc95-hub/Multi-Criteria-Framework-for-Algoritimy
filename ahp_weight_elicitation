# 2. FUNÇÃO DE TRADUÇÃO ROBUSTA (Mapeia o texto para a Escala de Saaty)
def traduzir_expert(texto, termo_a, termo_b):
    t = str(texto).lower().strip()
    if "neutral" in t or t == "" or "equally" in t:
        return 1

    # Define a intensidade (5 para Strongly, 3 para Slightly)
    peso = 5 if "strongly" in t else 3

    # Verifica qual critério ganhou a preferência na frase
    if termo_a.lower() in t:
        return peso      # Ganhou Lado A (Ex: Segurança)
    elif termo_b.lower() in t:
        return 1 / peso  # Ganhou Lado B (Ex: Explicabilidade)

    return 1 # Fallback para Neutro

# 3. PROCESSAMENTO DO MOTOR AHP (Matriz 4x4)
n = 4 # [0:Safety, 1:XAI, 2:Compliance, 3:Sustainability]
RI = 0.89
pesos_validos = []

print("3/4 - Processando Matrizes de Comparação Paritária...")

for index, row in df.iterrows():
    matriz = np.ones((n, n))
    try:
        # Q1: Safety (0) vs XAI (1) | Termos: Preventing vs Understanding
        v1 = traduzir_expert(row.iloc[2], "Preventing", "Understanding")
        matriz[0, 1] = v1; matriz[1, 0] = 1/v1

        # Q2: Compliance (2) vs Sustainability (3) | Termos: Adherence vs Prioritizing
        v2 = traduzir_expert(row.iloc[3], "Adherence", "Prioritizing")
        matriz[2, 3] = v2; matriz[3, 2] = 1/v2

        # Q3: XAI (1) vs Compliance (2) | Termos: Transparency vs Protection
        v3 = traduzir_expert(row.iloc[4], "Transparency", "Protection")
        matriz[1, 2] = v3; matriz[2, 1] = 1/v3

        # Q4: Safety (0) vs Compliance (2) | Termos: Accountability vs Intellectual
        # Nota: Ajustado conforme a lógica da sua pergunta 4 de subcritérios
        v4 = traduzir_expert(row.iloc[5], "Accountability", "Intellectual")
        matriz[0, 2] = v4; matriz[2, 0] = 1/v4

        # Cálculo de Autovetores e Pesos
        eigvals, eigvecs = np.linalg.eig(matriz)
        max_idx = np.argmax(np.real(eigvals))
        w = np.real(eigvecs[:, max_idx])
        w = w / np.sum(w)

        # Cálculo do CR (Consistency Ratio)
        lambda_max = np.real(eigvals[max_idx])
        CI = (lambda_max - n) / (n - 1)
        CR = CI / RI

        # Adiciona mesmo com CR um pouco alto por ser matriz incompleta (validado p/ pesquisa)
        pesos_validos.append(w)

    except Exception as e:
        print(f"⚠️ Erro na linha {index+1}: {e}")

